{
  "name": "agents-playground",
  "version": "0.0.1",
  "description": "Weather Dashboard app, a polished Next.js app that displays current conditions and a short forecast for a chosen city using either OpenWeatherMap API. Key features: city search, display current weather and 5-day forecast, save a list of favorite cities.",
  "homepage": "https://github.com/andriipugach/agents-playground#readme",
  "bugs": {
    "url": "https://github.com/andriipugach/agents-playground/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andriipugach/agents-playground.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "rm -rf .next/types .next/dev/types && tsc --noEmit",
    "lint-staged": "lint-staged",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "mcp:analytics": "tsx mcp/analytics/server.ts",
    "mcp:analytics:debug": "node --inspect-brk --import tsx mcp/analytics/server.ts",
    "mcp:analytics:inspect": "npx @modelcontextprotocol/inspector",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:validate": "prisma migrate deploy && prisma migrate status",
    "prisma:push": "prisma db push",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "next": "^16.2.7",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
